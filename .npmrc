save-exact=false
package-lock=true
engine-strict=false

# --- Package registry --------------------------------------------------------
# Point the @ifmis scope at the GitLab project Package Registry so that
# `npm publish` NEVER targets the public npmjs registry by accident.
#
# Replace <PROJECT_ID> with this project's numeric ID (Settings → General).
# The auth token is NOT stored here — CI writes a fresh .npmrc with the token
# at publish time (see PUBLISHING.md §6), and local maintainers add the token
# line to their personal ~/.npmrc (see PUBLISHING.md §3.5).
@ifmis:registry=http://172.18.210.110/api/v4/projects/45/packages/npm/
